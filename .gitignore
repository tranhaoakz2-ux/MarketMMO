# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma / sqlite
/prisma/*.db
/prisma/*.db-journal

# file đính kèm chat — KHÔNG commit, lưu ngoài /public để không bị truy cập công khai
/uploads/

# ảnh sản phẩm upload khi chạy dev local không cấu hình Vercel Blob (xem
# saveProductImage() trong src/lib/uploads.ts) — dữ liệu người dùng tải lên
# lúc chạy thử, không phải asset của dự án, KHÔNG commit
/public/uploads/

# cấu hình cục bộ Claude Code (không phải asset của dự án)
/.claude/settings.local.json
/.claude/scheduled_tasks.lock

# ảnh tham khảo/scratch ở gốc thư mục dùng trong lúc trao đổi thiết kế —
# không phải asset thật của app (asset thật đã nằm trong public/, không bị
# ảnh hưởng vì pattern có "/" ở đầu chỉ khớp file ngay tại thư mục gốc)
/*.png

# tài liệu audit/rà soát bảo mật + bản đồ kiến trúc — chứa chi tiết lỗ hổng/
# khai thác + cấu trúc nội bộ hệ thống production, CHỈ giữ ở local, TUYỆT ĐỐI
# không đưa lên remote (repo có thể public; GitHub cache/index kể cả sau khi xoá).
/AUDIT.md
/SECURITY_AUDIT.md
/*_AUDIT.md
/CCCD_REMOVAL.md
/PROJECT_MAP.md


# Local-only SQL previews (project uses prisma db push, no migrations)
/migrations-preview/
