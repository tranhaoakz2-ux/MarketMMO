generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Kept as plain strings (not native Prisma enums) even though PostgreSQL
// supports them — these fields were originally added on SQLite (no enum
// support there) and app code already treats them as validated strings via
// the TypeScript union types in src/lib/constants.ts. Converting to native
// `enum` blocks is a safe follow-up if wanted, but isn't required for the
// SQLite → PostgreSQL migration itself. Allowed values per field:
//   User.role            "BUYER" | "SELLER" | "ADMIN"
//   Order.status          "ESCROW" | "RELEASED" | "CANCELLED" | "DISPUTED"
//   OrderItem.status       same as Order.status
//   WalletTransaction.type   "DEPOSIT" | "PURCHASE" | "PAYOUT" | "REFUND" |
//                            "REFERRAL_BONUS" | "WITHDRAW" | "INSURANCE_DEPOSIT"
//   WalletTransaction.status "PENDING" | "CONFIRMED" | "REJECTED"
//   DiscountCode.type         "PERCENT" | "FIXED"
//   Dispute.status             "OPEN" | "RESOLVED_REFUND" | "RESOLVED_RELEASE"
//   Product.status             "PENDING" | "APPROVED" | "REJECTED"
//   Category.status            "PENDING" | "APPROVED" | "REJECTED"
//   ProductStockItem.status    "AVAILABLE" | "SOLD"

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  phone         String?
  role          String    @default("BUYER")
  walletBalance Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // Cập nhật trong callback jwt() của Auth.js (src/auth.ts) mỗi khi có phiên
  // đăng nhập/làm mới token (throttle 2 phút/lần để tránh ghi DB liên tục) —
  // dùng để hiển thị "Online X trước" ở trang chi tiết sản phẩm.
  lastActiveAt  DateTime?

  // Affiliate/giới thiệu: mã của chính người dùng này (chia sẻ cho người
  // khác) + liên kết tới người đã giới thiệu mình (nếu đăng ký qua mã mời).
  // Nullable vì các tài khoản có sẵn trước khi có tính năng này chưa có mã —
  // sinh "lười" (lazy) khi họ vào trang /affiliate lần đầu, xem
  // src/lib/referral.ts. Không dùng migration backfill vì dự án dùng
  // `prisma db push` (không có thư mục migrations).
  referralCode     String?  @unique
  referredById     String?
  referredBy       User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]   @relation("Referrals")
  // true khi người giới thiệu (referredBy) đã nhận hoa hồng cho CHÍNH user
  // này — đánh dấu trên người được mời (không phải người mời) để idempotent
  // dễ dàng dù có nhiều lượt mời khác nhau. Set true trong POST /api/checkout
  // khi đơn hàng đầu tiên của user này đủ điều kiện (xem REFERRAL_MIN_FIRST_ORDER_VND).
  referralRewarded Boolean  @default(false)

  // Khoá tài khoản (Admin > Người dùng) — chặn đăng nhập ngay (kiểm tra
  // trong Credentials authorize(), xem src/auth.ts), KHÔNG xoá dữ liệu.
  // Không áp dụng cho tài khoản Google OAuth hiện có (chỉ chặn được ở bước
  // authorize() của Credentials provider) — ghi rõ trong code phần đó.
  banned       Boolean   @default(false)
  bannedReason String?
  bannedAt     DateTime?

  // IP lúc đăng ký — dùng để GẮN CỜ (không chặn cứng) cặp referrer–referred
  // trùng IP để admin review (chống farming hoa hồng đa tài khoản). Xem
  // ReferralCommission.flagged + src/lib/commission.ts.
  signupIp String?

  accounts      Account[]
  sessions      Session[]
  seller        Seller?
  orders        Order[]
  walletTxs     WalletTransaction[]
  reviews       Review[]
  forumPosts    ForumPost[]
  forumComments ForumComment[]
  forumLikes    ForumLike[]
  forumReports  ForumReport[]
  disputesOpened Dispute[]
  conversationsAsUserA Conversation[] @relation("ConversationsAsUserA")
  conversationsAsUserB Conversation[] @relation("ConversationsAsUserB")
  sentMessages         Message[]
  passwordResetTokens  PasswordResetToken[]
  adminAuditLogs       AdminAuditLog[]
  commissionsEarned    ReferralCommission[] @relation("CommissionReferrer")
  commissionsGenerated ReferralCommission[] @relation("CommissionReferred")
  commissionsDisbursed ReferralCommission[] @relation("CommissionDisbursedBy")
  commissionRateChanges CommissionRateChange[]
  feeSchedulesCreated  PlatformFeeSchedule[] @relation("FeeScheduleCreatedBy")
  feeChanges           PlatformFeeChange[]   @relation("FeeChangedBy")
}

// Quên mật khẩu: token lưu dạng SHA-256 hash (không lưu token gốc) để dữ
// liệu bị rò rỉ từ DB không thể dùng trực tiếp reset mật khẩu người khác —
// token gốc (đủ entropy, 32 byte ngẫu nhiên) chỉ gửi qua email, xem
// src/lib/email.ts + src/app/api/auth/forgot-password/route.ts.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Seller {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopName     String
  slug         String   @unique
  description  String
  phone        String?
  facebookLink String?
  level       Int      @default(1)
  // Badge "Đã xác thực" hiển thị công khai trên gian hàng — TRƯỚC ĐÂY được
  // set tự động khi admin duyệt xác thực CCCD (model SellerVerification, đã
  // xoá bỏ hoàn toàn do liên quan dữ liệu cá nhân nhạy cảm). Giờ là cờ admin
  // TỰ BẬT/TẮT thủ công (Admin > Người bán, PATCH /api/admin/sellers/[id]
  // {action:"verify"|"unverify"}) theo đánh giá riêng — không còn quy trình
  // upload/duyệt giấy tờ nào đứng sau field này.
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  // Số dư quỹ bảo hiểm seller đã đóng lên sàn (hiển thị ở trang chi tiết sản
  // phẩm như 1 tín hiệu tin cậy, giống shopmini.pro) — nạp thật qua
  // /trang-ban-hang/quy-bao-hiem (POST /api/seller/insurance-deposit).
  insuranceBalance Int @default(0)

  // Telegram Bot (Trang Bán Hàng > Telegram Bot) — env-gated giống VNPay,
  // xem TELEGRAM_BOT_TOKEN trong .env.example. telegramLinkCode: mã 6 ký tự
  // tạm thời seller gửi cho bot qua lệnh /link để xác nhận đúng Chat ID là
  // của mình; xoá sau khi liên kết thành công. telegramChatId: null nghĩa là
  // chưa liên kết, không gửi thông báo.
  telegramChatId   String?
  telegramLinkCode String?

  // Khoá gian hàng (Admin > Người bán) — sản phẩm của seller vẫn còn trong
  // DB nhưng public query lọc thêm điều kiện seller.suspended=false nên
  // biến mất khỏi site (xem src/lib/queries.ts). Seller vẫn đăng nhập được
  // bình thường (không dùng User.banned) — chỉ gian hàng ngừng hoạt động.
  suspended       Boolean   @default(false)
  suspendedReason String?
  suspendedAt     DateTime?

  products       Product[]
  reviews        Review[]
  auctionBids    AuctionBid[]
  discountCodes  DiscountCode[]
  // Danh mục do chính seller này đề xuất (nút "+ Thêm danh mục mới" trong
  // form đăng sản phẩm) — chỉ để admin biết ai đã đề xuất, KHÔNG có UI riêng
  // cho seller theo dõi danh sách này (ngoài phạm vi, xem CLAUDE.md).
  proposedCategories Category[]
}

// Mã giảm giá do seller tự tạo, áp dụng cho TOÀN BỘ sản phẩm của chính họ
// (không áp dụng chéo sang sản phẩm seller khác trong cùng đơn) — xem
// POST /api/checkout để biết cách áp dụng an toàn trong 1 $transaction.
model DiscountCode {
  id        String    @id @default(cuid())
  sellerId  String
  seller    Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  code      String    @unique
  type      String // "PERCENT" | "FIXED"
  value     Int // % (1-100) nếu PERCENT, hoặc số tiền VNĐ cố định nếu FIXED
  maxUses   Int?
  usedCount Int       @default(0)
  active    Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

// Đấu giá "vị trí vàng" — seller trả giá để sản phẩm của mình hiện trong
// carousel "Sản phẩm nổi bật" ở trang chủ trong một khoảng thời gian.
//   position 1-4: period WEEKLY (1 tuần/phiên)
//   position 5-6: period DAILY  (1 ngày/phiên)
// status: "OPEN" | "CLOSED"
model AuctionSlot {
  id           String    @id @default(cuid())
  position     Int
  period       String
  floorPrice   Int
  startAt      DateTime
  endAt        DateTime
  status       String    @default("OPEN")
  winningBidId String?
  createdAt    DateTime  @default(now())

  bids AuctionBid[]
}

model AuctionBid {
  id        String      @id @default(cuid())
  slotId    String
  slot      AuctionSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  sellerId  String
  seller    Seller      @relation(fields: [sellerId], references: [id])
  productId String
  product   Product     @relation(fields: [productId], references: [id])
  amount    Int
  createdAt DateTime    @default(now())
}

model Review {
  id        String   @id @default(cuid())
  sellerId  String
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sellerId, userId])
}

model Category {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  emoji String

  // Seller có thể tự đề xuất danh mục mới (nút "+ Thêm danh mục mới" ở cuối
  // dropdown chọn danh mục trong AddProductForm) khi sản phẩm của họ chưa
  // khớp danh mục nào có sẵn — cần admin duyệt mới hiện công khai (trang
  // chủ/trang danh mục/mega-menu), giống hệt pattern Product.status.
  // @default("APPROVED") để 10 category seed có sẵn không bị ẩn khi thêm
  // field này (migration-safety, cùng lý do đã áp dụng cho Product.status).
  status       String  @default("APPROVED")
  adminNote    String?
  proposedById String?
  proposedBy   Seller? @relation(fields: [proposedById], references: [id], onDelete: SetNull)

  products Product[]
}

model Product {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  shortDescription String
  description      String
  attributes       String
  price            Int
  priceMax         Int?
  originalPrice    Int?
  stock            Int      @default(0)
  sold             Int      @default(0)
  views            Int      @default(0)
  rating           Float    @default(4.5)
  reviewCount      Int      @default(0)
  verified         Boolean  @default(false)
  hot              Boolean  @default(false)
  featuredUntil    DateTime?
  createdAt        DateTime @default(now())
  // Seller đánh dấu "sắp có hàng" (Trang Bán Hàng > Đặt trước). Buyer vẫn
  // trả 100% tiền như checkout bình thường (giữ nguyên hệ thống escrow có
  // sẵn) nhưng POST /api/checkout BỎ QUA kiểm tra tồn kho cho sản phẩm này
  // — stock có thể xuống 0/âm, đó là tín hiệu seller đang "nợ hàng" cần giao.
  preOrder         Boolean  @default(false)

  // Ảnh sản phẩm thật do seller tự upload (Vercel Blob URL hoặc đường dẫn
  // /uploads/products/... khi chạy dev local không có BLOB_READ_WRITE_TOKEN
  // — xem saveProductImage() trong src/lib/uploads.ts). null thì UI tự động
  // fallback về icon theo category như trước (ProductThumbnail.tsx).
  imageUrl  String?
  // "PENDING" | "APPROVED" | "REJECTED" — sản phẩm seller tự đăng qua
  // POST /api/seller/products bắt đầu ở "PENDING", cần admin duyệt
  // (POST /api/admin/products/[id]) mới hiện công khai. Default "APPROVED"
  // (không phải "PENDING") để toàn bộ sản phẩm cũ tạo qua prisma/seed.ts
  // (đã có sẵn từ trước, coi như đã duyệt) không bị ẩn khỏi site khi field
  // này được thêm vào — API tạo sản phẩm mới set "PENDING" tường minh,
  // không dựa vào default.
  status    String   @default("APPROVED")
  adminNote String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  sellerId   String
  seller     Seller   @relation(fields: [sellerId], references: [id])

  orderItems  OrderItem[]
  auctionBids AuctionBid[]
  variants    ProductVariant[]
  stockItems  ProductStockItem[]
}

// Biến thể/gói của 1 sản phẩm — vd Gmail: "Domain .US - Thuê 24h - Tên Việt"
// vs "Domain .Com - Thuê 24h" — mỗi biến thể có giá/kho riêng, seller tự
// thêm/sửa/xoá tại trang quản lý (src/app/quan-ly-san-pham). Khi 1 sản phẩm
// có >=1 variant, trang chi tiết sản phẩm bắt buộc chọn 1 variant trước khi
// mua — giá/kho hiệu lực lấy từ variant thay vì từ Product (Product.price/
// stock vẫn giữ nguyên làm giá trị "mặc định" cho sản phẩm chưa có variant
// nào, tương thích ngược với toàn bộ sản phẩm seed cũ).
model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String
  price     Int
  stock     Int      @default(0)
  sold      Int      @default(0)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  orderItems OrderItem[]
  stockItems ProductStockItem[]
}

// Kho dữ liệu giao hàng THẬT — mỗi dòng là 1 đơn vị nội dung có thể giao cho
// đúng 1 buyer (vd 1 dòng "email|password|2fa" của 1 tài khoản Gmail, 1 mã
// kích hoạt Steam key...). Seller nhập hàng loạt (mỗi dòng textarea = 1 bản
// ghi) qua Trang Bán Hàng > Sản phẩm — xem POST /api/seller/products/
// [productId]/stock. Đây là điểm khác biệt CỐT LÕI so với Product.stock/
// ProductVariant.stock (chỉ là 1 con số seller tự gõ tay, không gắn nội dung
// giao hàng thật) — model này giữ chỗ cho việc DELIVERY THẬT: khi buyer mua,
// POST /api/checkout tự động "claim" đúng số lượng bản ghi AVAILABLE, gắn
// vào OrderItem.deliveredPayload (buyer xem tại /don-hang).
//
// Sản phẩm/biến thể chỉ chuyển sang "chế độ kho thật" khi seller đã từng
// nhập >=1 bản ghi ở đây (kiểm tra bằng COUNT, không cần thêm cờ boolean
// riêng) — 180+ sản phẩm cũ chưa từng nhập kho thật vẫn hoạt động y hệt như
// trước (Product.stock/ProductVariant.stock vẫn là nguồn kiểm tra tồn kho
// duy nhất, deliveredPayload luôn null), không có gì bị phá vỡ.
model ProductStockItem {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  // null khi sản phẩm CHƯA có variant nào (kho gắn thẳng vào Product) — có
  // giá trị khi kho thuộc về 1 variant cụ thể. onDelete: SetNull (không
  // Cascade) để bản ghi ĐÃ BÁN (status SOLD, đã gắn vào 1 OrderItem) không
  // bao giờ bị xoá khi seller xoá variant sau này — lịch sử giao hàng của
  // buyer phải giữ nguyên vĩnh viễn. Bản ghi CHƯA BÁN (AVAILABLE) của 1
  // variant sắp xoá phải được dọn tường minh TRƯỚC khi xoá variant (xem
  // DELETE /api/seller/products/[productId]/variants/[variantId]) để tránh
  // bị "mồ côi" lẫn sang kho của Product gốc.
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  // Nội dung giao hàng thật (email:password, mã kích hoạt...) — seller tự
  // nhập, không validate format cụ thể vì mỗi category 1 kiểu dữ liệu khác
  // nhau (Gmail vs Discord vs Steam key vs gold...).
  content String
  // "AVAILABLE" | "SOLD" — chuyển sang SOLD NGAY khi bị claim trong
  // transaction checkout (không đợi tới lúc gắn xong orderItemId) để chặn
  // đúng trường hợp giỏ hàng có 2 dòng trùng productId+variantId (client gửi
  // thẳng lên API, không qua CartContext dedup) claim trúng cùng 1 bản ghi.
  status      String    @default("AVAILABLE")
  orderItemId String?
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  soldAt      DateTime?

  @@index([productId, variantId, status])
}

model Order {
  id          String   @id @default(cuid())
  buyerId     String
  buyer       User     @relation(fields: [buyerId], references: [id])
  totalAmount Int
  status      String   @default("ESCROW")
  createdAt   DateTime @default(now())
  // Ghi lại mã giảm giá ĐÃ ÁP DỤNG cho đơn này (nếu có) để đối chiếu lịch sử
  // — không dùng để tính lại tiền, chỉ mang tính hiển thị/audit.
  discountCode   String?
  discountAmount Int      @default(0)

  items    OrderItem[]
  // Hoa hồng affiliate của đơn này (nếu buyer được giới thiệu) — 1-1, tạo ở
  // POST /api/checkout với status PENDING, chốt (ELIGIBLE/CANCELLED) khi đơn
  // giải ngân xong (xem src/lib/commission.ts).
  referralCommission ReferralCommission?
}

model OrderItem {
  id               String   @id @default(cuid())
  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product  @relation(fields: [productId], references: [id])
  sellerId         String
  productName      String
  // Snapshot tên + id variant tại thời điểm mua (variantId nullable + xoá
  // thì SetNull, KHÔNG cascade) — giữ nguyên variantLabel hiển thị trong
  // lịch sử đơn hàng ngay cả khi seller đã xoá variant đó sau này.
  variantId        String?
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantLabel     String?
  quantity         Int
  price            Int
  status           String   @default("ESCROW")
  escrowReleaseAt  DateTime
  // Nội dung giao hàng thật — JSON string mảng (1 phần tử / 1 đơn vị đã mua,
  // khớp `quantity`), lấy từ ProductStockItem.content tại thời điểm checkout
  // claim được đủ hàng trong kho thật (xem model ProductStockItem). null khi
  // sản phẩm/biến thể CHƯA từng dùng kho thật (chế độ cũ — stock chỉ là số
  // seller tự gõ tay, không có nội dung để giao) — giữ nguyên hành vi cũ cho
  // toàn bộ đơn hàng/sản phẩm có từ trước tính năng này.
  deliveredPayload String?
  // PHÍ SÀN — snapshot FREEZE tại thời điểm đặt đơn (tính hoàn toàn ở server
  // trên giá SAU giảm giá của dòng hàng này). Đổi % phí về sau KHÔNG hồi tố
  // đơn cũ vì đã lưu cứng ở đây. Giải ngân cho seller = price*quantity −
  // platformFeeAmount (xem escrow/release + disputes). Áp cho MỌI đơn/mọi
  // seller, không phụ thuộc có giới thiệu hay không.
  platformFeePercent Float @default(0)
  platformFeeAmount  Int   @default(0)
  createdAt        DateTime @default(now())

  dispute    Dispute?
  stockItems ProductStockItem[]
}

// Khiếu nại (Trang Bán Hàng > Khiếu nại) — buyer hoặc seller mở trên 1
// OrderItem đang ESCROW (chuyển OrderItem.status sang "DISPUTED" để loại khỏi
// vòng giải ngân tự động của admin/escrow/release). CHỈ admin quyết định kết
// quả cuối: hoàn toàn bộ tiền cho buyer HOẶC giải ngân cho seller — không có
// hoàn tiền một phần, giữ đúng pattern "admin tự quyết" xuyên suốt dự án.
model Dispute {
  id          String    @id @default(cuid())
  orderItemId String    @unique
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  openedById  String
  openedBy    User      @relation(fields: [openedById], references: [id])
  reason      String
  status      String    @default("OPEN") // "OPEN" | "RESOLVED_REFUND" | "RESOLVED_RELEASE"
  adminNote   String?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
}

// Diễn đàn cộng đồng — bất kỳ user đăng nhập nào cũng đăng bài, bình luận
// (đóng vai trò "chat" theo từng bài viết) và thả tim 1 bài viết. Trước đây
// dữ liệu chỉ là mock tĩnh (src/data/posts.ts), giờ là dữ liệu thật.
model ForumPost {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("Chia sẻ")
  createdAt DateTime @default(now())
  // Admin ẩn bài vi phạm sau khi xử lý báo cáo (Admin > Diễn đàn) — ẩn khỏi
  // mọi query công khai, KHÔNG xoá cứng để giữ lịch sử kiểm duyệt.
  hidden    Boolean  @default(false)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  comments ForumComment[]
  likes    ForumLike[]
  reports  ForumReport[]
}

model ForumComment {
  id        String    @id @default(cuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime  @default(now())
  hidden    Boolean   @default(false)

  reports ForumReport[]
}

// Báo cáo bài viết/bình luận vi phạm (nút "Báo cáo" trên Diễn đàn) — đúng 1
// trong 2 khoá postId/commentId có giá trị, khoá còn lại null. Admin xử lý
// tại Admin > Diễn đàn: ẩn nội dung (set hidden=true) hoặc bỏ qua báo cáo.
model ForumReport {
  id         String        @id @default(cuid())
  postId     String?
  post       ForumPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId  String?
  comment    ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User          @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reason     String
  status     String        @default("OPEN") // "OPEN" | "RESOLVED_HIDDEN" | "RESOLVED_DISMISSED"
  createdAt  DateTime      @default(now())

  // Mỗi user chỉ báo cáo 1 lần cho cùng 1 bài viết / 1 bình luận (chống spam
  // ngập hàng chờ kiểm duyệt — AUDIT.md #4). postId/commentId nullable: Postgres
  // coi NULL là KHÁC NHAU trong unique index, nên report bài viết (commentId=NULL)
  // và report bình luận (postId=NULL) không đụng nhau — đúng ý muốn.
  @@unique([reporterId, postId])
  @@unique([reporterId, commentId])
}

// Nhật ký thao tác quản trị (Admin > Nhật ký hoạt động) — ghi lại MỌI hành
// động duyệt/từ chối/giải ngân/khoá tài khoản... kèm admin thực hiện, phục
// vụ đối soát và trách nhiệm giải trình khi xử lý tiền/tài khoản người dùng.
// Ghi qua src/lib/audit.ts, gọi thêm 1 dòng ở cuối mỗi route admin hiện có
// — không throw nếu ghi log lỗi (không được để lỗi audit làm hỏng thao tác
// chính đã thành công).
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String
  targetType String
  targetId   String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// Mỗi user chỉ thả tim 1 lần/bài viết — bấm lại để bỏ thích (toggle qua
// @@unique, xem POST /api/forum/posts/[postId]/like).
model ForumLike {
  id        String    @id @default(cuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([postId, userId])
}

model WalletTransaction {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  type        String
  amount      Int
  status      String    @default("PENDING")
  method      String?
  note        String?
  adminNote   String?
  gatewayRef  String?
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?
}

// Chat giữa 2 user bất kỳ (buyer-seller, hoặc user với bot "Hệ Thống" —
// xem src/lib/system-bot.ts) — KHÔNG dùng khái niệm buyer/seller cứng vì hội
// thoại với bot không khớp khung đó. userAId/userBId LUÔN được chuẩn hoá
// (id nhỏ hơn xếp vào userAId) khi tạo/tìm hội thoại để 1 cặp user chỉ có
// đúng 1 Conversation dù ai nhắn trước — xem getOrCreateConversation().
model Conversation {
  id            String   @id @default(cuid())
  userAId       String
  userA         User     @relation("ConversationsAsUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId       String
  userB         User     @relation("ConversationsAsUserB", fields: [userBId], references: [id], onDelete: Cascade)
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  messages Message[]

  @@unique([userAId, userBId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  // Ảnh/file đính kèm (tuỳ chọn) — lưu ngoài /public (xem src/lib/uploads.ts),
  // chỉ đọc qua GET /api/messages/attachments/[messageId]
  // (verify người gọi là 1 trong 2 người tham gia hội thoại). attachmentType:
  // "IMAGE" | "FILE". content có thể rỗng nếu tin chỉ có đính kèm.
  attachmentPath String?
  attachmentName String?
  attachmentType String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())
}

// Hoa hồng affiliate — GHI NHẬN khi buyer (được giới thiệu) đặt đơn, nhưng
// chỉ ĐỦ ĐIỀU KIỆN giải ngân sau khi đơn RELEASED (đã qua cửa sổ ký quỹ =
// qua cửa sổ hoàn tiền/khiếu nại). Tiền hoa hồng lấy từ PHÍ MARGIN sàn thu
// trên chính giao dịch đó (chỉ thu phí ở đơn có giới thiệu — xem
// src/lib/commission.ts + escrow release), và server đảm bảo commissionAmount
// ≤ phần margin thu được (commissionPercent < marginPercent, chốt ở settings).
//   status: "PENDING"  = chờ đủ điều kiện (đơn chưa giải ngân xong)
//           "ELIGIBLE" = đủ điều kiện, chờ admin giải ngân
//           "PAID"     = đã giải ngân vào ví người giới thiệu
//           "CANCELLED"= đơn bị hoàn/huỷ hết → hoa hồng bị huỷ
model ReferralCommission {
  id             String    @id @default(cuid())
  referrerId     String
  referrer       User      @relation("CommissionReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String
  referredUser   User      @relation("CommissionReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  orderId        String    @unique
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Giá trị đơn dùng để tính (chốt lúc tạo; cập nhật lại theo phần RELEASED
  // thực tế khi finalize nếu có item bị huỷ).
  orderAmount    Int
  commissionAmount Int
  // % chốt tại thời điểm phát sinh (KHÔNG hồi tố khi admin đổi % sau này).
  percentApplied       Float
  marginPercentApplied Float
  status         String    @default("PENDING")
  // Cờ đáng ngờ (không chặn cứng) — vd referrer & referred trùng signupIp.
  flagged        Boolean   @default(false)
  flaggedReason  String?
  eligibleAt     DateTime?
  paidAt         DateTime?
  disbursedById  String?
  disbursedBy    User?     @relation("CommissionDisbursedBy", fields: [disbursedById], references: [id])
  createdAt      DateTime  @default(now())

  @@index([referrerId, status])
  @@index([status])
}

// Cấu hình hoa hồng (singleton, id cố định "singleton") — admin sửa qua UI
// (Admin > Hoa hồng > Cài đặt), KHÔNG hardcode trong env.
// Ràng buộc bắt buộc ở server (mục #8): commissionPercent < phí_sàn / 2 —
// để "phần sàn thực thu ròng" (= phí sàn − hoa hồng) luôn LỚN HƠN hoa hồng.
// platformMarginPercent giữ lại cho tương thích ngược (không còn dùng làm trần
// — trần giờ suy từ PlatformFeeSetting).
model CommissionSetting {
  id                   String   @id
  commissionPercent    Float    // vd 4 = 4%
  platformMarginPercent Float   // (deprecated — xem PlatformFeeSetting)
  perReferrerCap       Int      @default(0) // 0 = không giới hạn (VNĐ / kỳ)
  capPeriodDays        Int      @default(30)
  // Kill switch (mục #9B) — TẮT thì NGỪNG phát sinh hoa hồng MỚI kể từ thời
  // điểm tắt; KHÔNG đụng các khoản đã kiếm hợp lệ (vẫn ELIGIBLE/PAID/giải ngân
  // được). Kiểm tra cờ này ở server (accrueCommission) trước khi tạo commission.
  enabled              Boolean  @default(true)
  updatedAt            DateTime @updatedAt
  updatedById          String?
}

// PHÍ SÀN — % chung cho MỌI seller/mọi đơn. Singleton (id "singleton") lưu %
// MẶC ĐỊNH; các mốc theo thời gian (PlatformFeeSchedule) ghi đè trong khoảng
// hiệu lực. Admin sửa qua UI (Admin > Phí sàn), KHÔNG hardcode env. % mới chỉ
// áp cho đơn phát sinh SAU (đơn cũ freeze snapshot ở OrderItem, không hồi tố).
model PlatformFeeSetting {
  id                String   @id
  defaultFeePercent Float
  updatedAt         DateTime @updatedAt
  updatedById       String?
}

// Lịch phí theo thời gian (mục #9A) — trong [startAt, endAt] áp feePercent, hết
// kỳ tự về defaultFeePercent. Server chọn đúng % hiệu lực tại thời điểm đặt đơn.
// KHÔNG cho khoảng chồng lấn (validate server). Xoá/sửa được, ghi audit log.
model PlatformFeeSchedule {
  id          String   @id @default(cuid())
  feePercent  Float
  startAt     DateTime
  endAt       DateTime
  createdById String
  createdBy   User     @relation("FeeScheduleCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([startAt, endAt])
}

// Lịch sử đổi % phí sàn MẶC ĐỊNH — ai đổi, từ bao nhiêu sang bao nhiêu, lúc nào
// (thay đổi mốc lịch phí ghi qua AdminAuditLog).
model PlatformFeeChange {
  id          String   @id @default(cuid())
  changedById String
  changedBy   User     @relation("FeeChangedBy", fields: [changedById], references: [id])
  oldPercent  Float
  newPercent  Float
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// Lịch sử đổi % hoa hồng/margin — ai đổi, từ bao nhiêu sang bao nhiêu, lúc nào.
model CommissionRateChange {
  id                   String   @id @default(cuid())
  changedById          String
  changedBy            User     @relation(fields: [changedById], references: [id])
  oldCommissionPercent Float
  newCommissionPercent Float
  oldMarginPercent     Float
  newMarginPercent     Float
  createdAt            DateTime @default(now())

  @@index([createdAt])
}
