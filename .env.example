# Database (PostgreSQL qua Docker — xem docker-compose.yml, chạy `docker compose up -d`)
DATABASE_URL="postgresql://marketmmo:marketmmo@localhost:5433/marketmmo"

# Auth.js (NextAuth v5) — tạo secret ngẫu nhiên: openssl rand -base64 32
AUTH_SECRET=""

# Đăng nhập Google (điền để bật nút "Đăng nhập với Google")
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Xác minh chống bot Cloudflare Turnstile cho đăng nhập/đăng ký (điền để bật —
# SITE_KEY dùng ở client nên bắt buộc prefix NEXT_PUBLIC_, SECRET_KEY chỉ dùng
# server-side). Lấy tại https://dash.cloudflare.com/ > Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Cổng thanh toán VNPay (điền để bật nạp tiền tự động qua VNPay)
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
VNPAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:3000/api/payment/vnpay/return"

# Chuyển khoản ngân hàng thủ công — điền để hiện số tài khoản thật cho người
# nạp tiền (thiếu thì vẫn nhận được yêu cầu nạp tiền nhưng không hiện số tài
# khoản cụ thể, admin cần tự liên hệ hướng dẫn).
# BANK_BIN là mã ngân hàng theo chuẩn Napas (dùng để tạo mã QR VietQR động qua
# img.vietqr.io, tự điền đúng số tiền + nội dung chuyển khoản theo từng yêu cầu
# nạp tiền) — điền kèm BANK_NAME/BANK_ACCOUNT_NUMBER để hiện QR, thiếu thì vẫn
# hiện số tài khoản dạng chữ như bình thường, chỉ không có ảnh QR.
# Một số mã BIN phổ biến: Vietcombank 970436, VietinBank 970415,
# BIDV 970418, Techcombank 970407, MB Bank 970422, ACB 970416, TPBank 970423.
BANK_NAME=""
BANK_ACCOUNT_NUMBER=""
BANK_ACCOUNT_HOLDER=""
BANK_BIN=""

# Nạp tiền bằng USDT mạng TRC20 — điền địa chỉ ví thật để bật tính năng.
USDT_TRC20_ADDRESS=""
USDT_VND_RATE="25400"

# Telegram Bot (Quản Lý Bán Hàng > Telegram Bot) — điền để bật tính năng liên
# kết Chat ID + gửi thông báo. Tạo bot qua @BotFather trên Telegram để lấy
# token. Thiếu key thì tính năng tự ẩn/disable, không chặn phần còn lại của app.
TELEGRAM_BOT_TOKEN=""

# Gửi email qua Resend (dùng cho luồng "Quên mật khẩu") — lấy API key tại
# https://resend.com/api-keys. Thiếu key thì link đặt lại mật khẩu chỉ in ra
# console server thay vì gửi email thật (vẫn test được đầy đủ ở dev).
# RESEND_FROM_EMAIL mặc định dùng địa chỉ sandbox onboarding@resend.dev của
# Resend (chỉ gửi được tới đúng email đã đăng ký tài khoản Resend) — cần xác
# minh 1 domain thật trên Resend rồi đổi sang địa chỉ @domain đó mới gửi được
# cho người dùng bất kỳ.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="MarketMMO <onboarding@resend.dev>"

# Lưu trữ ảnh sản phẩm + file đính kèm chat qua Vercel Blob — BẮT BUỘC khi deploy
# lên Vercel (filesystem serverless không lưu trữ lâu dài, ghi vào ổ đĩa cục
# bộ sẽ mất). Vào Vercel Dashboard > dự án > Storage > Create Database >
# Blob để tạo, token tự động điền vào biến môi trường của Vercel — copy giá
# trị đó vào đây nếu muốn dùng Blob khi chạy dev local. Thiếu token thì tự
# động ghi vào thư mục /uploads trên ổ đĩa cục bộ (chỉ phù hợp dev/host có
# filesystem lâu dài, KHÔNG dùng được trên Vercel).
BLOB_READ_WRITE_TOKEN=""

# Tài khoản admin được tạo khi chạy seed
ADMIN_EMAIL="admin@marketmmo.pro"
ADMIN_PASSWORD="Admin@123456"
